# cp .env.example .env  и заполни значения

# ── VK бот (обязательно) ──────────────────────────────────────────────────────
# Токен сообщества: Управление -> Настройки -> Работа с API -> Ключи доступа
VK_TOKEN=vk1.a.xxxxxxxxxx

# ID сообщества (число, без минуса): vk.com/club123456 -> 123456
VK_GROUP_ID=123456

# Твой личный VK ID (узнать: vk.com/id, или vk.com/@id<число>)
VK_ADMIN_ID=123456789

# ── Snort IDS ─────────────────────────────────────────────────────────────────
SNORT_ENABLED=true
SNORT_ALERT_FILE=/var/log/snort/alert
SNORT_PRIORITY=3

# ── iptables ──────────────────────────────────────────────────────────────────
IPTABLES_ENABLED=true
IPTABLES_LOG_FILE=/var/log/host/kern.log

# ── Авто-блокировка ───────────────────────────────────────────────────────────
# Автоматически блокировать IP если событий >= порога за окно времени
AUTO_BLOCK=false
AUTO_BLOCK_THRESHOLD=10
AUTO_BLOCK_WINDOW=300

# ── Прочее ────────────────────────────────────────────────────────────────────
DEDUP_WINDOW=60
POLL_INTERVAL=1.0
